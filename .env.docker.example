# Docker deployment environment TEMPLATE — copy to `.env` next to the Compose files
# and fill in real values. NEVER commit the filled-in .env (see .gitignore).
#
# Generate APP_KEY once with:
#   docker compose -f compose.deploy.yml run --rm --no-deps app php artisan key:generate --show
# Paste the "base64:..." result below.

APP_NAME="智能手机目录"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Database (the compose `db` service) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# --- Sessions / cache / queue (database-backed by default) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
# HTTPS in production: only send the session cookie over TLS.
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

# --- Search driver: `like` (default) or `fulltext` (needs the ngram index) ---
CATALOG_SEARCH_DRIVER=like

# --- Host port nginx is published on (http://localhost:${WEB_PORT}) ---
WEB_PORT=8080

# --- Prebuilt Docker Hub images ---
# Pin both to matching role-version tags (for example runtime-v1.0.0 and
# web-v1.0.0) when you need a reproducible release or rollback.
DOCKER_APP_IMAGE=generalpeople/smartphone-catalog:runtime
DOCKER_WEB_IMAGE=generalpeople/smartphone-catalog:web

# --- Mail (optional) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"
