{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": "^22.18.0 || >=24.11.0"
    },
    "scripts": {
        "build": "npm run build:admin && npm run build:frontend",
        "build:admin": "vite build",
        "build:frontend": "npm --prefix frontend run build",
        "check": "npm run check:open-source && npm run lint:frontend && npm run format:check:frontend && npm run test:frontend",
        "check:open-source": "node scripts/check-open-source-boundary.mjs",
        "dev": "npm run dev:admin",
        "dev:admin": "vite",
        "dev:frontend": "npm --prefix frontend run dev",
        "format:frontend": "npm --prefix frontend run format",
        "format:check:frontend": "npm --prefix frontend run format:check",
        "install:frontend": "npm --prefix frontend ci",
        "lint:frontend": "npm --prefix frontend run lint",
        "test:frontend": "npm --prefix frontend run test"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.2",
        "alpinejs": "^3.15.12",
        "concurrently": "^10.0.3",
        "laravel-vite-plugin": "^3.1.3",
        "tailwindcss": "^4.3.0",
        "vite": "^8.1.4"
    }
}
